# Локально: полный URL API или прокси Vite — /api
VITE_API_BASE_URL=http://localhost:8080/api
# Username бота без @ — тот же бот, чей TG_TOKEN на бэкенде (для Login Widget)
VITE_TELEGRAM_BOT_NAME=open21vpn_bot
# Полные ссылки на Telegram-бот и поддержку
VITE_TELEGRAM_BOT_URL=
VITE_TELEGRAM_SUPPORT_URL=
# OAuth 2.0 Client ID из Google Cloud Console (Web application)
VITE_GOOGLE_CLIENT_ID=
